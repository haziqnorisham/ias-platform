# HTTP Server
HTTP_SERVER_PORT=8080
HTTP_SERVER_AUTOSTART=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ias_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_INVALIDATION_SECOND=60

# InfluxDB
INFLUXDB_URL=https://influxdb.com
INFLUXDB_TOKEN=token_here
INFLUXDB_ORG=sample_org

# IAS HC Backend Server
IAS_HC_BACKEND_ENABLE=true

# STI Automation
STI_AUTOMATION_ENABLE=false

# MQTT Sensor Monitoring
MQTT_ENABLED=true
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=ias_automation_sensors
MQTT_TOPIC=/sensor/+/{device_id}/up
MQTT_QOS=0

# Worker
WORKER_ENABLED=true
WORKER_COUNT=0
WORKER_POLL_INTERVAL=5s
WORKER_BATCH_SIZE=20
WORKER_PROCESS_ORDER=asc

# === Authentication (LDAP) ===
AUTH_ENABLED=false

LDAP_URL=ldaps://dc.example.com:636
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=readonly,dc=example,dc=com
LDAP_BIND_PASSWORD=changeme
LDAP_USER_FILTER=(sAMAccountName=%s)
LDAP_ADMIN_GROUP=cn=IAS_Admins,ou=groups,dc=example,dc=com
LDAP_TLS_INSECURE=false
LDAP_STARTTLS=false